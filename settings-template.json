{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git tag*)",
      "Bash(git remote -v*)",
      "Bash(git remote --verbose*)",

      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm run typecheck*)",
      "Bash(pnpm exec tsc*)",
      "Bash(npx tsc*)",

      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm exec vitest*)",
      "Bash(pnpm exec playwright*)",
      "Bash(pnpm --filter * test*)",
