      "Bash(pnpm --filter * build*)",

      "Bash(ls*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(echo*)",

      "Bash(pnpm list*)",
      "Bash(pnpm why*)",
      "Bash(pnpm outdated*)",

      "Bash(curl -s http://localhost:*)",
