{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git tag*)",
      "Bash(git remote -v*)",
      "Bash(git remote --verbose*)",

      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm run typecheck*)",
      "Bash(pnpm exec tsc*)",
      "Bash(pnpm --filter * exec tsc*)",
      "Bash(npx tsc*)",

      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm exec vitest*)",
      "Bash(pnpm exec playwright*)",
      "Bash(pnpm --filter * test*)",
      "Bash(pnpm --filter * exec vitest*)",
      "Bash(pnpm --filter * exec playwright*)",

      "Bash(pnpm build*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm --filter * build*)",

      "Bash(ls*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(echo*)",
      "Bash(sed*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(xargs*)",
      "Bash(which*)",
      "Bash(node --version*)",
      "Bash(node -e*)",
      "Bash(node -p*)",
      "Bash(du*)",
      "Bash(stat*)",
      "Bash(type*)",
      "Bash(pwd*)",
      "Bash(dirname*)",
      "Bash(basename*)",

      "Bash(pnpm list*)",
      "Bash(pnpm why*)",
      "Bash(pnpm outdated*)",

      "Bash(curl -s http://localhost:*)",
      "Bash(curl --silent http://localhost:*)"
    ],
    "ask": [
      "Bash(git push origin main*)",
      "Bash(git push origin dev*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git tag -d*)",
      "Bash(git push origin :refs/tags/*)"
    ]
  }
}
